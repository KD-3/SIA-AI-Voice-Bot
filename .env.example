# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Sarvam AI Configuration (Indian TTS)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_SPEAKER=priya

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aivoicebot
REDIS_URL=redis://localhost:6379/0

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=voice-bot-knowledge

# HubSpot Configuration (Optional)
HUBSPOT_API_KEY=your_hubspot_api_key_here

# Salesforce Configuration (Optional)
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_USERNAME=your_salesforce_username
SALESFORCE_PASSWORD=your_salesforce_password

# Google Calendar Configuration (Optional)
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google-calendar-creds.json

# SendGrid Configuration (Optional)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourcompany.com

# Application Configuration
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Security
SECRET_KEY=your-secret-key-for-jwt-signing
API_KEY=your-api-key-for-dashboard-auth

# Feature Flags
ENABLE_CALL_RECORDING=true
ENABLE_ANALYTICS=true
ENABLE_CRM_SYNC=false
