# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=DEBUG

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── Sarvam / ElevenLabs (TTS) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Twilio (inbound / SMS) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Exotel (outbound calls) ───────────────────────────────────────────────────
EXOTEL_ACCOUNT_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_PHONE_NUMBER=08047xxxxxx

# ── ngrok (local dev tunnel) ─────────────────────────────────────────────────
ENABLE_NGROK=true
NGROK_AUTH_TOKEN=your_ngrok_auth_token

# ── Firebase / Firestore ──────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=../path/to/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CALENDAR_SERVICE_ACCOUNT_PATH=../path/to/service-account.json
GOOGLE_CALENDAR_DELEGATE_EMAIL=admin@yourdomain.com
